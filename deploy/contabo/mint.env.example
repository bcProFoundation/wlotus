# Contabo mint-api secrets (test)
#
# Runtime: mint-api reads this file on the VM (NOT from GitHub at request time).
# Prefer creating this on the server once. Optionally sync from GitHub Actions
# secret MINT_MNEMONIC during deploy (see deploy-web-test.yml).
#
# chmod 600 /etc/wlotus/mint.env

# Preferred — 12 or 24 words (space-separated)
# MINT_MNEMONIC=word1 word2 ... word12

# Or 32-byte hex (legacy / genesis dogfood)
# MINT_SK_HEX=
# GENESIS_SK_HEX=

MINT_API_PORT=8787

# Daily offerings per installId (test dryrun default in code is 20)
# MINT_MAX_OFFERS_PER_DAY=20
