[Unit]
Description=WLotus Prayer mint API (dual-mint)
After=network.target

[Service]
Type=simple
User=deploy
WorkingDirectory=/opt/wlotus
# Do NOT use EnvironmentFile for MINT_MNEMONIC (spaces break systemd).
# server.ts loads /etc/wlotus/mint.env via dotenv.
Environment=NODE_ENV=production
Environment=MINT_API_PORT=8787
ExecStart=/opt/wlotus/deploy/contabo/run-mint-api.sh
Restart=on-failure
RestartSec=5
# Long remint PoW can take minutes
TimeoutStartSec=0

[Install]
WantedBy=multi-user.target
