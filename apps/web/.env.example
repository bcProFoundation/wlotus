# White Lotus web — Offer client (mobile-first)
# Defaults in code are dWLOTUS; override only if needed.
VITE_PRAYER_TICKER=dWLOTUS
# VITE_PRAYER_TOKEN_ID=a38825a5afae52895126a77287a1f2480f0a8813699b824a5cbfc390cc0d2838
# Empty = same-origin / Vite proxy to mint API
# VITE_MINT_API_BASE=

# Minimum prayer wall time (ms) before submit if PoW finishes early. Default 60000.
# Set 0 to disable. Runtime override: localStorage wlotus.minPrayMs
# VITE_MIN_PRAY_MS=60000

# Experimental phone PoW (research only — official Offer path is single CPU worker).
# See docs/research/phone-webgpu-wasm-mining.md
# VITE_EXPERIMENTAL_POW=1
# Force multi-core CPU (skip WebGPU): multi-worker | cpu | webgpu | worker | auto
# VITE_POW_BACKEND=multi-worker
