# White Lotus web — Offer client (mobile-first)
# Defaults in code are dWLOTUS; override only if needed.
VITE_PRAYER_TICKER=dWLOTUS
# VITE_PRAYER_TOKEN_ID=a38825a5afae52895126a77287a1f2480f0a8813699b824a5cbfc390cc0d2838
# Empty = same-origin / Vite proxy to mint API
# VITE_MINT_API_BASE=

# Soft pray floor after remint, before memorial burn. Default 60 seconds.
# Set 0 to disable. Runtime override: localStorage wlotus.minPrayS
# VITE_MIN_PRAY_S=60

# Launch mining: WebGPU → multi-worker → single (requires rebuild).
# See docs/research/phone-webgpu-wasm-mining.md
# VITE_EXPERIMENTAL_POW=1
# Optional: auto | webgpu | multi-worker | worker
# VITE_POW_BACKEND=auto
