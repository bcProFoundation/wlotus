{
  "name": "wlotus",
  "version": "0.1.0",
  "description": "WLOTUS: Ergon-like ALP PoW remint + offerings on eCash",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "moore": "tsx scripts/compute-moore.ts",
    "pricing": "tsx scripts/compute-pricing.ts",
    "lint": "tsc -p tsconfig.json --noEmit && npm run lint -w @wlotus/web",
    "web": "npm run dev -w @wlotus/web",
    "web:build": "npm run build -w @wlotus/web",
    "mint-api": "tsx apps/mint-api/src/server.ts",
    "dana-index": "tsx apps/dana-index/src/server.ts",
    "new-wallet": "tsx scripts/new-wallet.ts",
    "create-test-token": "tsx scripts/create-test-token.ts",
    "wait-create-test-token": "tsx scripts/wait-for-funding-and-create.ts",
    "mine-once": "tsx scripts/mine-once.ts",
    "create-pow-token": "tsx scripts/create-pow-token.ts",
    "create-moore-pow-token": "tsx scripts/create-moore-pow-token.ts",
    "mine-moore-once": "tsx scripts/mine-moore-once.ts",
    "create-ergon-pow-token": "tsx scripts/create-ergon-pow-token.ts",
    "mine-ergon-once": "tsx scripts/mine-ergon-once.ts",
    "create-prayer-pow-token": "tsx scripts/create-prayer-pow-token.ts",
    "mine-prayer-once": "tsx scripts/mine-prayer-once.ts",
    "create-prayer-tip-pow-token": "tsx scripts/create-prayer-tip-pow-token.ts",
    "mine-prayer-tip-once": "tsx scripts/mine-prayer-tip-once.ts",
    "create-wlotus-token": "tsx scripts/create-wlotus-token.ts",
    "create-prod-token": "tsx scripts/create-wlotus-token.ts",
    "create-dryrun-wlotus": "TICKER=dWLOTUS tsx scripts/create-wlotus-token.ts",
    "create-dryrun-token": "tsx scripts/create-dryrun-token.ts",
    "mine-dryrun-once": "tsx scripts/mine-dryrun-once.ts",
    "smoke-moore-tip-temple": "tsx scripts/smoke-moore-tip-temple.ts",
    "wait-create-mwlotus": "tsx scripts/wait-create-mwlotus.ts",
    "fund-tip-fee-wallets": "tsx scripts/fund-tip-fee-wallets.ts",
    "sweep-temple-to-cold": "tsx scripts/sweep-temple-to-cold.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@spedn/rts": "^5.0.0",
    "@spedn/rts-bchjs": "^5.0.0",
    "@spedn/sdk": "^5.0.0",
    "chronik-client": "^4.3.0",
    "dotenv": "^16.4.7",
    "ecash-lib": "^4.13.0",
    "ecash-wallet": "^6.1.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bcProFoundation/wlotus.git"
  },
  "license": "MIT"
}
